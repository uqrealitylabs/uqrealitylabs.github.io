{
  "schemaVersion": 1,
  "requiredPaths": [
    ".github/workflows",
    "docs/README.md",
    "src",
    "tests",
    "tools/config",
    "tools/scripts",
    "package.json",
    "package-lock.json"
  ],
  "forbiddenTopLevelPaths": ["config", "configs", "scripts", "cypress"],
  "allowedRootConfigShims": ["biome.json", "tsconfig.json"],
  "generatedPaths": ["coverage", "dist", "build", "test-results/cypress"],
  "allowedSingleFileDirs": [
    "src/content/generated",
    "src/content/graph",
    "src/content/schema",
    "src/seo",
    "src/shared/i18n",
    "src/shared/testing",
    "src/shared/ui",
    "tests/cypress/component",
    "tools/scripts/repo",
    "tools/scripts/security",
    "tools/scripts/wiki"
  ]
}
