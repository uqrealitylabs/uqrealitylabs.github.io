{
  "name": "uqrealitylabs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "rsbuild dev",
    "prebuild": "npm run check:no-js && npm run validate:content && npm run seo:check",
    "build": "rsbuild build",
    "preview": "rsbuild preview",
    "ci": "npm run ci:quality && npm run ci:build",
    "ci:quality": "npm run check:no-js && npm run validate:content && npm run seo:check && npm run typecheck && npm run lint && npm run format:check && npm run test:coverage",
    "ci:build": "npm run build && npm run check:budgets && node scripts/collect-benchmarks.ts --out artifacts/benchmarks/build.json",
    "ci:security": "npm run check:workflows && npm run security:audit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:no-js": "node scripts/assert-no-js.ts",
    "check:actions-pinned": "node scripts/assert-actions-pinned.ts",
    "check:workflows": "npm run check:actions-pinned",
    "check:budgets": "node scripts/collect-benchmarks.ts --check-budgets",
    "validate:content": "node scripts/validate-content.ts",
    "seo:generate": "node scripts/generate-seo.ts",
    "seo:validate": "node scripts/validate-seo.ts",
    "seo:check": "npm run seo:validate",
    "test": "vitest run",
    "test:unit": "vitest run",
    "test:component": "cypress run --component",
    "test:e2e": "cypress run --e2e",
    "test:coverage": "vitest run --coverage.enabled true",
    "test:ci": "npm run ci:quality && npm run ci:build",
    "analyze": "npm run benchmark:build",
    "benchmark": "npm run benchmark:build",
    "benchmark:build": "npm run build && node scripts/collect-benchmarks.ts --out artifacts/benchmarks/build.json",
    "assets:optimize": "node scripts/optimize-assets.ts",
    "security:audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@uqrealitylabs/eyslie": "git+https://github.com/uqrealitylabs/eyslie.git#9d633f5",
    "@uqrealitylabs/feelable-materials": "git+https://github.com/uqrealitylabs/feelable-materials.git#abcf8e3",
    "gsap": "^3.15.0",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.177.0",
    "troika-three-text": "^0.52.4"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.3.8",
    "@gltf-transform/cli": "^4.2.1",
    "@rsbuild/core": "^2.1.4",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@rsdoctor/rspack-plugin": "^1.5.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "^4.1.10",
    "cypress": "^15.7.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.0.15"
  }
}
