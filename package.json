{
  "name": "uqrealitylabs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "rsbuild dev --config tools/config/rsbuild.config.ts",
    "prebuild": "npm run validate:content && npm run seo:check",
    "build": "rsbuild build --config tools/config/rsbuild.config.ts",
    "preview": "rsbuild preview --config tools/config/rsbuild.config.ts",
    "ci": "npm run ci:quality && npm run ci:build",
    "ci:quality": "npm run repo:check && npm run config:check && npm run validate:content && npm run seo:check && npm run typecheck && npm run lint && npm run format:check && npm run test:coverage",
    "ci:build": "npm run build && npm run check:budgets && node tools/scripts/collect-benchmarks.ts --out artifacts/benchmarks/build.json",
    "ci:security": "npm run check:workflows && npm run security:audit && npm run security:osv",
    "repo:check": "npm run repo:check:layout && npm run check:no-js",
    "repo:check:layout": "node tools/scripts/repo/validate-layout.ts",
    "config:check": "npm run release:validate",
    "typecheck": "tsc --noEmit",
    "lint": "mise run lint",
    "lint:fix": "mise run format",
    "format": "mise run format",
    "format:check": "mise run format-check",
    "check:no-js": "node tools/scripts/assert-no-js.ts",
    "check:workflows": "mise run workflow-check",
    "check:budgets": "node tools/scripts/collect-benchmarks.ts --check-budgets",
    "validate:content": "node tools/scripts/validate-content.ts",
    "seo:generate": "node tools/scripts/generate-seo.ts",
    "seo:validate": "node tools/scripts/validate-seo.ts",
    "seo:check": "npm run seo:validate",
    "test": "vitest run --config tools/config/vitest.config.ts",
    "test:unit": "vitest run --config tools/config/vitest.config.ts",
    "test:component": "cypress run --component --config-file tools/config/cypress.config.ts",
    "test:e2e": "cypress run --e2e --config-file tools/config/cypress.config.ts",
    "test:coverage": "vitest run --config tools/config/vitest.config.ts --coverage.enabled true",
    "test:ci": "npm run ci:quality && npm run ci:build",
    "analyze": "npm run benchmark:build",
    "benchmark": "npm run benchmark:build",
    "benchmark:build": "npm run build && node tools/scripts/collect-benchmarks.ts --out artifacts/benchmarks/build.json",
    "assets:optimize": "node tools/scripts/optimize-assets.ts",
    "security:audit": "npm audit --audit-level=moderate",
    "security:osv": "node tools/scripts/security/osv-audit.ts",
    "release:validate": "node tools/scripts/release/validate-codenames.ts && node tools/scripts/release/generate-codename.ts 1.2.3 >/dev/null",
    "release:codename": "node tools/scripts/release/generate-codename.ts",
    "wiki:check": "node tools/scripts/wiki/validate-wiki.ts"
  },
  "dependencies": {
    "@uqrealitylabs/eyslie": "git+https://github.com/uqrealitylabs/eyslie.git#e69149302a14887d7d1824549e216e69c635555c",
    "@uqrealitylabs/feelable-materials": "git+https://github.com/uqrealitylabs/feelable-materials.git#68363f093ac9cb49bb21773b0ebda16a3715ddab",
    "@react-three/fiber": "^9.6.1",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.177.0"
  },
  "devDependencies": {
    "@gltf-transform/cli": "^4.2.1",
    "@rsbuild/core": "^2.1.4",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@rsdoctor/rspack-plugin": "^1.5.17",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.177.0",
    "@vitest/coverage-v8": "^4.1.10",
    "cypress": "^15.7.0",
    "tailwindcss": "^4.1.17",
    "typescript": "^5.9.3",
    "vite": "^6.4.3",
    "vitest": "^4.0.15"
  }
}
