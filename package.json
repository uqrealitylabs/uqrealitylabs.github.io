{
  "name": "uqrealitylabs",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@11.12.1",
  "scripts": {
    "dev": "rsbuild dev --config tools/configs/rsbuild.config.ts",
    "prebuild": "npm run check:no-js && npm run validate:content && npm run seo:check",
    "build": "rsbuild build --config tools/configs/rsbuild.config.ts",
    "preview": "rsbuild preview --config tools/configs/rsbuild.config.ts",
    "ci": "npm run ci:quality && npm run ci:build",
    "ci:quality": "npm run check:no-js && npm run validate:content && npm run seo:check && npm run typecheck && npm run lint && npm run format:check && npm run test:unit",
    "ci:build": "npm run build && npm run check:budgets && node tools/scripts/collect-benchmarks.ts --out artifacts/benchmarks/build.json",
    "ci:security": "npm run check:workflows && npm run security:audit",
    "typecheck": "tsc --noEmit",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "check:no-js": "node tools/scripts/assert-no-js.ts",
    "check:actions-pinned": "node tools/scripts/assert-actions-pinned.ts",
    "check:workflows": "npm run check:actions-pinned",
    "check:budgets": "node tools/scripts/collect-benchmarks.ts --check-budgets",
    "validate:content": "node tools/scripts/validate-content.ts",
    "seo:generate": "node tools/scripts/generate-seo.ts",
    "seo:validate": "node tools/scripts/validate-seo.ts",
    "seo:check": "npm run seo:validate",
    "test": "vitest run --config tools/configs/vitest.config.ts",
    "test:unit": "vitest run --config tools/configs/vitest.config.ts",
    "test:component": "cypress run --project . --config-file tools/configs/cypress.config.ts --component",
    "test:e2e": "cypress run --project . --config-file tools/configs/cypress.config.ts --e2e",
    "test:ci": "npm run ci:quality && npm run ci:build",
    "analyze": "npm run benchmark:build",
    "benchmark": "npm run benchmark:build",
    "benchmark:build": "npm run build && node tools/scripts/collect-benchmarks.ts --out artifacts/benchmarks/build.json",
    "assets:optimize": "node tools/scripts/optimize-assets.ts",
    "security:audit": "npm audit --audit-level=moderate"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.4.0",
    "@react-three/postprocessing": "^3.0.4",
    "gsap": "^3.15.0",
    "maath": "^0.10.8",
    "motion": "^12.23.26",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "three": "^0.185.1",
    "troika-three-text": "^0.52.4",
    "zustand": "^5.0.9"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.4",
    "@gltf-transform/cli": "^4.2.1",
    "@rsbuild/core": "^2.1.6",
    "@rsbuild/plugin-react": "^2.1.0",
    "@rsbuild/plugin-tailwindcss": "^2.0.3",
    "@rsdoctor/rspack-plugin": "^1.6.0",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "cypress": "^15.18.1",
    "gltfpack": "^1.2.0",
    "meshoptimizer": "^1.2.0",
    "tailwindcss": "^4.3.3",
    "typescript": "^7.0.2",
    "vite": "^8.1.5",
    "vitest": "^4.0.15"
  }
}
