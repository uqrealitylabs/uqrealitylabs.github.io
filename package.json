{
  "name": "uqrealitylabs",
  "private": true,
  "version": "0.0.0",
  "description": "Website for the University of Queensland Reality Labs society.",
  "type": "module",
  "engines": {
    "node": ">=20.18.0"
  },
  "scripts": {
    "dev": "vite --config config/vite.config.ts",
    "build": "vite build --config config/vite.config.ts",
    "preview": "vite preview --config config/vite.config.ts",
    "format": "biome format --config-path config/biome.json --write .",
    "format:check": "biome format --config-path config/biome.json .",
    "lint": "biome lint --config-path config/biome.json .",
    "lint:fix": "biome lint --config-path config/biome.json --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:unit": "vitest run --config config/vitest.config.ts",
    "test": "vitest run --config config/vitest.config.ts",
    "check": "npm run format:check && npm run lint && npm run typecheck && npm run test:unit && npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.15.18",
    "jsdom": "^26.1.0",
    "typescript": "^5.9.2",
    "vitest": "^3.2.4",
    "vite": "^6.3.5"
  },
  "dependencies": {
    "gsap": "^3.15.0",
    "three": "^0.177.0",
    "troika-three-text": "^0.52.4"
  }
}
